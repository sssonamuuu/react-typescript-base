{
  "presets": [
    [
      "@babel/preset-env",
      {
        "modules": false,
        "targets": {"browsers": ["> 1%", "last 2 versions"]}
      }
    ],
    ["@babel/preset-react"],
    ["@babel/preset-typescript"]
  ],
  "plugins": [
    ["@babel/plugin-transform-runtime"], // polyfill 按需引入
    ["import", { "libraryName": "antd",  "style": true }] // antd 按需引入
  ]
}